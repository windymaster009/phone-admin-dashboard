# Use a dedicated database name for this project. Do not commit real credentials.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/phone_shop?retryWrites=true&w=majority&appName=PhoneFlow
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_EXPIRES_IN=12h
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development
