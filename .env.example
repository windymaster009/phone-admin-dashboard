# Use a dedicated database name for this project. Do not commit real credentials.
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER/phone_shop?retryWrites=true&w=majority&appName=PhoneFlow
JWT_SECRET=GENERATE_A_NEW_RANDOM_SECRET_AT_LEAST_32_CHARACTERS
JWT_EXPIRES_IN=12h
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development

# Remote Atlas clusters can briefly pause or reconnect. Keep operation timeouts
# long enough that an acknowledged write is not reported to the UI as a 500.
MONGO_SERVER_SELECTION_TIMEOUT_MS=30000
MONGO_CONNECT_TIMEOUT_MS=30000
MONGO_SOCKET_TIMEOUT_MS=60000
MONGO_MAX_POOL_SIZE=10

# ABA PayWay is server-only. Never prefix these names with VITE_ and never put
# the API key in frontend code. Start disabled until ABA sends sandbox
# credentials and whitelists the backend IP/domain.
PAYWAY_ENABLED=false
PAYWAY_ENV=sandbox
PAYWAY_BASE_URL=https://checkout-sandbox.payway.com.kh
PAYWAY_MERCHANT_ID=YOUR_ABA_PAYWAY_MERCHANT_ID
PAYWAY_API_KEY=YOUR_ABA_PAYWAY_API_KEY
PAYWAY_CALLBACK_URL=
PAYWAY_REQUEST_TIMEOUT_MS=10000

# KHQR only, using ABA's QR image template 3.
PAYWAY_QR_TEMPLATE=template3_color
PAYWAY_QR_LIFETIME_MINUTES=6

# Select the ABA USD/KHR side required by the shop's conversion policy.
# Confirm buy vs sell with ABA before production.
PAYWAY_USD_KHR_RATE_SIDE=buy
USD_KHR_FALLBACK_RATE=4100
